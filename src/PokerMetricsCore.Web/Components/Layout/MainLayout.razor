@inherits LayoutComponentBase

<div class="page-wrapper">
    <nav class="navbar navbar-expand-md navbar-dark bg-dark shadow-sm py-3">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
