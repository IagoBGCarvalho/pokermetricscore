@page "/upload/ignition"
@using Microsoft.EntityFrameworkCore 
@using PokerMetricsCore.Web.Data 
@using PokerMetricsCore.Web.Services
@inject ProcessamentoArquivoService ProcessingService
@inject NavigationManager Nav
@inject IDbContextFactory<PokerMetricsCoreContext> DbFactory

<PageTitle>Upload Ignition - PokerMetricsCore</PageTitle>

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Upload Ignition</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h4 class="mb-0">Upload de Extrato - Ignition</h4>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-4">Selecione o arquivo <strong>.xlsx</strong> baixado diretamente do portal da sua conta.</p>

                    <div class="mb-4">
                        <InputFile OnChange="HandleFileSelected" class="form-control form-control-lg" accept=".xlsx" />
                    </div>

                    @if (isLoading)
                    {
                        <div class="d-flex align-items-center text-primary mb-3">
                            <div class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></div>
                            <strong>Processando transações e realizando matching...</strong>
                        </div>
                    }
                    
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center" role="alert">
                            <div>@errorMessage</div>
                        </div>
                    }
                </div>
                <div class="card-footer bg-white p-3 d-flex justify-content-end border-top-0">
                    @* Transformamos em um botão outline vermelho para não chamar clique acidental *@
                    <button class="btn btn-sm btn-outline-danger" @onclick="ResetDatabase">
                        ⚠️ Limpar Dados Desta Plataforma
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isLoading = false;
    private string errorMessage = "";

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        isLoading = true;
        errorMessage = "";

        try
        {
            var file = e.File;
            // Limite de segurança para upload (ex: 5MB)
            long maxFileSize = 5 * 1024 * 1024; 

            // Copia o stream do arquivo para a memória (necessário para o ClosedXML funcionar)
            using var stream = new MemoryStream();
            await file.OpenReadStream(maxFileSize).CopyToAsync(stream);
            stream.Position = 0;

            // Chama o serviço
            await ProcessingService.ProcessamentoFluxoArquivoAsync(stream, file.Name, "Iago Carvalho");

            // Redireciona para o relatório
            Nav.NavigateTo("/reports/ignition");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro no upload: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
    private async Task ResetDatabase()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        // Apaga os dados na ordem correta (filhos primeiro)
        context.Transacao.RemoveRange(context.Transacao);
        context.TorneioJogado.RemoveRange(context.TorneioJogado);
        context.Arquivo.RemoveRange(context.Arquivo);
        // Não apaga Players nem TournamentDefinitions para não perder o cadastro
        
        await context.SaveChangesAsync();
        errorMessage = "Banco de dados limpo com sucesso!";
    }
}